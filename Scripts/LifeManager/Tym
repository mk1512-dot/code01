using UnityEngine;
using UnityEngine.UI;

public class LifeManager : MonoBehaviour
{
    public static LifeManager Instance;

    [SerializeField] int maxLives = 3; 
    // 👉 số mạng ban đầu (ví dụ: 3)

    int currentLives;
    // 👉 số mạng hiện tại (sẽ thay đổi khi chơi)

    [SerializeField] Image[] hearts;
    // 👉 MẢNG chứa các trái tim UI
    // hearts[0] = tim 1
    // hearts[1] = tim 2
    // hearts[2] = tim 3

    void Awake()
    {
        // Singleton (chỉ 1 LifeManager)
        if (Instance == null)
            Instance = this;
        else
            Destroy(gameObject);
    }

    void Start()
    {
        currentLives = maxLives;
        // 👉 bắt đầu game: currentLives = 3

        UpdateHeartsUI();
        // 👉 cập nhật UI lần đầu
    }

    public void LoseLife()
    {
        currentLives--;
        // 👉 mất 1 mạng

        UpdateHeartsUI();
        // 👉 cập nhật lại tim trên màn hình

        if (currentLives <= 0)
        {
            GameOver();
        }
    }

    void UpdateHeartsUI()
    {
        // 👉 chạy qua từng trái tim
        for (int i = 0; i < hearts.Length; i++)
        {
            // i = 0 → tim 1
            // i = 1 → tim 2
            // i = 2 → tim 3

            if (i < currentLives)
            {
                hearts[i].enabled = true;
                // 👉 nếu còn mạng → HIỆN tim
            }
            else
            {
                hearts[i].enabled = false;
                // 👉 nếu hết mạng → ẨN tim
            }
        }
    }

    void GameOver()
    {
        Debug.Log("GAME OVER");
        Time.timeScale = 0f;
    }
}
