using UnityEngine;

public class PlayerScript : MonoBehaviour
{
    Rigidbody2D rb;
    [SerializeField] float MoveSpeed;
    Vector2 minBounds;
    Vector2 maxBounds;
    float halfWidth;
    float halfHeight;
    float InputX;
    private void Awake()
    {
        rb = GetComponent<Rigidbody2D>();

    }
    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        SetupCam();
        SpriteRenderer sr = GetComponent<SpriteRenderer>();
        halfWidth = sr.bounds.extents.x;
        halfHeight = sr.bounds.extents.y;
    }
    void SetupCam()
    {
        Camera cam = Camera.main;
        float hight = cam.orthographicSize;
        float wight = hight * cam.aspect;
        Vector3 campos = cam.transform.position;
        minBounds = new Vector2(campos.x - wight, campos.y - hight);
        maxBounds = new Vector2(campos.x + wight, campos.y + hight);
    }

    // Update is called once per frame
    void Update()
    {
        InputX = Input.GetAxis("Horizontal");
    }
    private void FixedUpdate()
    {
        Move();
        ClampPosition();
    }
    void Move()
    {

        rb.linearVelocity = new Vector2(InputX * MoveSpeed, rb.linearVelocity.y);
    }
    void ClampPosition()
    {
        Vector2 pos = rb.position;
        pos.x = Mathf.Clamp(pos.x, minBounds.x + halfWidth, maxBounds.x - halfWidth);
        pos.y = Mathf.Clamp(pos.y,
                            minBounds.y + halfHeight,
                            maxBounds.y - halfHeight);
        rb.position = pos;
    }
    private void OnCollisionEnter2D(Collision2D collision)
    {
        if (collision.gameObject.CompareTag("enemy")){
            Debug.Log("Game Over");
        }
    }
}
