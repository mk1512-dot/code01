using Unity.Mathematics;
using UnityEngine;

public class PlayerController : MonoBehaviour
{
    bool canMove = true;
    [SerializeField] float moveSpeed;
    float InputX;
    Rigidbody2D rb;
    Vector2 minBounds;
    Vector2 maxBounds;
    bool CanMoveGameOver = true;
    private void Awake()
    {
        rb = GetComponent<Rigidbody2D>();
        
    }
    void Start()
    {
        Camera cam = Camera.main;
        float hight = cam.orthographicSize;
        float wight = hight * cam.aspect;
        Vector3 campos = cam.transform.position;
        minBounds = new Vector2(campos.x - wight, campos.y - hight);
        maxBounds = new Vector2(campos.x + wight, campos.y + hight);
    }
    void Update()
    {
        if (CanMoveGameOver == false)
        {
            return;
        }
        InputX = Input.GetAxis("Horizontal");
    }
    private void FixedUpdate()
    {
        if (CanMoveGameOver == false)
        {
            return;
        }
        Move();
    }
    void Move()
    {
        
        rb.linearVelocity = new Vector2(InputX * moveSpeed, rb.linearVelocity.y);
        Vector2 pos = rb.position;
        pos.x = Mathf.Clamp(pos.x, minBounds.x, maxBounds.x);
        pos.y = Mathf.Clamp(pos.y, minBounds.y, maxBounds.y);
        rb.position = pos;
    }
    private void OnTriggerEnter2D(Collider2D collision)
    {
        if (collision.gameObject.CompareTag("Coin"))
        {
            CoinScoreScript coinScoreScript = collision.GetComponent<CoinScoreScript>();
            
            if (coinScoreScript != null)
            {
                coinScoreScript.collect();
                
            }
        }
    }
    public void gameOverMove()
    {
        CanMoveGameOver = false;
        rb.linearVelocity = Vector2.zero;
    }
}
